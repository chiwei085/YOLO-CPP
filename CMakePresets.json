{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 20,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "environment": {
        "VCPKG_ROOT": "$penv{HOME}/.local/share/vcpkg",
        "VCPKG_OVERLAY_PORTS": "${sourceDir}/vcpkg-overlay-ports",
        "VCPKG_BINARY_SOURCES": "clear"
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CMAKE_TOOLCHAIN_FILE": "$penv{HOME}/.local/share/vcpkg/scripts/buildsystems/vcpkg.cmake"
      }
    },
    {
      "name": "dev",
      "displayName": "Dev (CPU, shared ORT)",
      "inherits": "base",
      "binaryDir": "${sourceDir}/build/dev",
      "cacheVariables": {
        "YOLO_CPP_ORT_PROVIDER": "cpu",
        "VCPKG_MANIFEST_FEATURES": "cpu",
        "VCPKG_TARGET_TRIPLET": "x64-linux-dynamic"
      }
    },
    {
      "name": "dev-opencv",
      "displayName": "Dev (CPU, Release OpenCV examples)",
      "inherits": "base",
      "binaryDir": "${sourceDir}/build/dev-opencv",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "YOLO_CPP_ORT_PROVIDER": "cpu",
        "VCPKG_MANIFEST_FEATURES": "cpu",
        "VCPKG_TARGET_TRIPLET": "x64-linux-dynamic",
        "YOLO_CPP_BUILD_PPM_EXAMPLES": "OFF",
        "YOLO_CPP_BUILD_OPENCV_EXAMPLES": "ON"
      }
    },
    {
      "name": "dev-cuda",
      "displayName": "Dev (CUDA)",
      "inherits": "base",
      "binaryDir": "${sourceDir}/build/cuda",
      "cacheVariables": {
        "YOLO_CPP_ORT_PROVIDER": "cuda",
        "VCPKG_MANIFEST_FEATURES": "cuda"
      }
    },
    {
      "name": "ci",
      "displayName": "CI Baseline (CPU, tests/tools)",
      "inherits": "base",
      "binaryDir": "${sourceDir}/build/ci",
      "cacheVariables": {
        "YOLO_CPP_ORT_PROVIDER": "cpu",
        "VCPKG_MANIFEST_FEATURES": "cpu",
        "VCPKG_TARGET_TRIPLET": "x64-linux-dynamic",
        "YOLO_CPP_BUILD_EXAMPLES": "OFF",
        "YOLO_CPP_BUILD_DIAGNOSTICS": "ON",
        "YOLO_CPP_BUILD_INTEGRATION_TESTS": "OFF",
        "BUILD_TESTING": "ON"
      }
    },
    {
      "name": "ci-full",
      "displayName": "CI Full Gate (CPU, assets/parity)",
      "inherits": "base",
      "binaryDir": "${sourceDir}/build/ci-full",
      "cacheVariables": {
        "YOLO_CPP_ORT_PROVIDER": "cpu",
        "VCPKG_MANIFEST_FEATURES": "cpu",
        "VCPKG_TARGET_TRIPLET": "x64-linux-dynamic",
        "YOLO_CPP_BUILD_EXAMPLES": "OFF",
        "YOLO_CPP_BUILD_DIAGNOSTICS": "ON",
        "YOLO_CPP_BUILD_INTEGRATION_TESTS": "ON",
        "BUILD_TESTING": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "build",
      "configurePreset": "dev"
    },
    {
      "name": "build-cuda",
      "configurePreset": "dev-cuda"
    },
    {
      "name": "build-opencv",
      "configurePreset": "dev-opencv"
    },
    {
      "name": "build-ci",
      "configurePreset": "ci"
    },
    {
      "name": "build-ci-full",
      "configurePreset": "ci-full"
    }
  ]
}
